# 1. Secret & Environment Files (Strictly Do Not Commit!)
.env
.env.local
.env.*.local
*.pem
*.key
*.p12

# 2. Python & Virtual Environments
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
*.egg
venv/
.venv/
env/
ENV/
.pytest_cache/
.coverage
htmlcov/
*.coverage

# 3. Local Databases, Cache & User Uploads
backend/data/*.db
backend/data/*.db-journal
backend/data/*.sqlite
backend/data/*.sqlite3
backend/data/.cache/
backend/data/uploads/*
backend/data/uploads/**
!backend/data/uploads/.gitkeep
backend/data/vector_store/*
backend/data/vector_store/**
!backend/data/vector_store/.gitkeep
backend/data/voice/*
backend/data/voice/**
!backend/data/voice/.gitkeep

# 4. Node.js & Frontend Build Outputs
node_modules/
frontend/node_modules/
dist/
build/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

