# =========================================================================
# READOO AI - ENVIRONMENT CONFIGURATION (.env)
# =========================================================================

# 1. APPLICATION & SERVER SETTINGS
PYTHON_HOST=127.0.0.1
PYTHON_PORT=5000

# 2. CORE SECURITY & SEED ACCOUNT CREDENTIALS
# Encrypts API keys stored in SQLite database (generate with Fernet.generate_key())
ENCRYPTION_KEY=TrGBorFNd00aBjsMIfu6IK31Kyfi8blz9Q_HHaHivu8=

# Seed Accounts (Used during initial DB seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
DEMO_USERNAME=user
DEMO_PASSWORD=user

# 3. DATABASE & CACHE SETTINGS
DATABASE_PATH=data/readoo.db
REDIS_HOST=localhost
REDIS_PORT=6379

# 4. PURE ONNX EMBEDDING MODEL (PyTorch-free semantic vector search)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# 5. VOICE STT MODEL (Whisper options: tiny | base | small | medium | large)
WHISPER_MODEL=base

# 6. LOCAL OLLAMA SERVER (Optional)
OLLAMA_BASE_URL=http://localhost:11434

# NOTE: LLM API Keys (Groq, OpenAI, Gemini, OpenRouter), LLM Models, 
# and TTS Settings (Voice, Language) are managed directly via 
# Admin Panel (Settings UI) and stored in SQLite database.
